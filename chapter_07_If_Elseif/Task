

//Even or Odd
let a = 7;
if ((a % 2) === 0) {
    console.log(a + " is even")
} else {
    console.log(a + " is odd")
}

//Scorecard

let score = 75;
if (score >= 90) {
    console.log("Grade is A");
} else if (score >= 80) {
    console.log("Grade is B");
} else if (score >= 70) {
    console.log("Grade is C");
} else if (score >= 60) {
    console.log("Grade is D");
} else {
    console.log("Fail");
}